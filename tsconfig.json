{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["bun-types"],
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@db/*": ["./src/db/*"],
      "@server/*": ["./src/server/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
